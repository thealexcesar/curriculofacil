{
  "app": {
    "subtitle": "Crie um currículo profissional em minutos",
    "title": "Currículo Fácil"
  },

  "btn": {
    "add": "Adicionar {{item}}",
    "finish": "Finalizar e Imprimir",
    "next": "Próximo",
    "prev": "Anterior",
    "print": "Imprimir / PDF",
    "remove": "Remover"
  },

  "document": { "filename": "curriculo" },

  "field": {
    "currentJob": { "label": "Trabalho atual" },
    "inProgress": { "label": "Cursando" },
    "degree": {
      "label": "Curso / Título",
      "placeholder": "Ex: Análise e Desenvolvimento de Sistemas"
    },
    "description": { "label": "Descrição" },
    "eduDescription": {
      "label": "Descrição (opcional)",
      "placeholder": "Informações adicionais, projetos relevantes..."
    },
    "email": {
      "error": {
        "invalid": "E-mail inválido",
        "required": "E-mail é obrigatório"
      },
      "label": "E-mail"
    },
    "endDate": { "label": "Data de Fim / Conclusão" },
    "expCompany": {
      "label": "Empresa",
      "placeholder": "Ex: Google"
    },
    "expDescription": {
      "placeholder": "Descreva suas principais responsabilidades..."
    },
    "expTitle": {
      "label": "Cargo",
      "placeholder": "Ex: Desenvolvedor Web"
    },
    "institution": {
      "label": "Instituição",
      "placeholder": "Ex: UNINTER"
    },
    "jobTitle": {
      "error": "Título é obrigatório",
      "label": "Título Profissional",
      "placeholder": "Ex: Desenvolvedora Web"
    },
    "language": {
      "label": "Idioma",
      "level": {
        "A1": "A1 - Iniciante",
        "A2": "A2 - Básico",
        "B1": "B1 - Intermediário",
        "B2": "B2 - Intermediário avançado",
        "C1": "C1 - Avançado",
        "C2": "C2 - Fluente",
        "native": "Nativo"
      },
      "levelLabel": "Nível",
      "placeholder": "Selecionar idioma..."
    },
    "linkedin": {
      "label": "LinkedIn",
      "placeholder": "https://linkedin.com/in/seuperfil"
    },
    "location": {
      "label": "Localização",
      "placeholder": "Ex: Blumenau, SC"
    },
    "month": { "placeholder": "Mês" },
    "year": { "placeholder": "Ano" },
    "name": {
      "error": "Nome é obrigatório",
      "label": "Nome Completo",
      "placeholder": "Ex: Maria da Silva"
    },
    "phone": {
      "error": "Telefone inválido (fixo ou celular)",
      "label": "Telefone",
      "note": { "placeholder": "Observação (ex: Trabalho, Recados...)" },
      "placeholder": "(00) 00000-0000"
    },
    "profile": {
      "error": "Limite de 400 caracteres atingido",
      "label": "Resumo Profissional",
      "placeholder": "Ex: Profissional com experiência em..."
    },
    "skill": {
      "label": "Habilidades",
      "placeholder": "Ex: JavaScript, Photoshop..."
    },
    "startDate": { "label": "Data de Início" },
    "experience": { "current": "Atual" }
  },

  "languages": {
    "arabic": "Árabe",
    "bengali": "Bengali",
    "catalan": "Catalão",
    "chinese": "Chinês",
    "czech": "Tcheco",
    "danish": "Dinamarquês",
    "dutch": "Holandês",
    "english": "Inglês",
    "esperanto": "Esperanto",
    "farsi": "Persa (Farsi)",
    "finnish": "Finlandês",
    "french": "Francês",
    "german": "Alemão",
    "greek": "Grego",
    "hebrew": "Hebraico",
    "hindi": "Hindi",
    "hungarian": "Húngaro",
    "indonesian": "Indonésio",
