    "japanese": "Japonês",
    "korean": "Coreano",
    "malay": "Malaio",
    "mandarin": "Mandarim",
    "norwegian": "Norueguês",
    "other": "Outro",
    "polish": "Polonês",
    "portuguese": "Português",
    "romanian": "Romeno",
    "russian": "Russo",
    "spanish": "Espanhol",
    "swahili": "Suaíli",
    "swedish": "Sueco",
    "thai": "Tailandês",
    "turkish": "Turco",
    "ukrainian": "Ucraniano",
    "vietnamese": "Vietnamita"
