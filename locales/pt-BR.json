  },

  "toast": {
    "close": { "aria": "Fechar notificação" },
    "finished": "Currículo finalizado!",
    "print": { "hint": "Desmarque \"Cabeçalhos e rodapés\" no diálogo de impressão" },
    "saved": "Salvo automaticamente"
  },

  "toggle": { "form": "Formulário", "preview": "Visualização" }
}
