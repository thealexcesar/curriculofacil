{
  "app": {
    "subtitle": "Erstellen Sie in wenigen Minuten einen professionellen Lebenslauf",
    "title": "Lebenslauf Einfach"
  },

  "btn": {
    "add": "{{item}} hinzufügen",
    "finish": "Fertigstellen",
    "next": "Weiter",
    "prev": "Zurück",
    "print": "Drucken / PDF",
    "remove": "Entfernen"
  },

  "document": { "filename": "lebenslauf" },

  "field": {
    "currentJob": { "label": "Aktuelle Stelle" },
    "inProgress": { "label": "Laufend" },
    "degree": {
      "label": "Abschluss / Titel",
      "placeholder": "z.B.: Informatik"
    },
    "description": { "label": "Beschreibung" },
    "eduDescription": {
      "label": "Beschreibung (optional)",
      "placeholder": "Zusätzliche Informationen, relevante Projekte..."
    },
    "email": {
      "error": {
        "invalid": "Ungültige E-Mail",
        "required": "E-Mail ist erforderlich"
      },
      "label": "E-Mail"
    },
    "endDate": { "label": "Enddatum" },
    "expCompany": {
      "label": "Unternehmen",
      "placeholder": "z.B.: Google"
    },
    "expDescription": {
      "placeholder": "Beschreiben Sie Ihre Hauptaufgaben..."
    },
    "expTitle": {
      "label": "Berufsbezeichnung",
      "placeholder": "z.B.: Webentwickler"
    },
    "institution": {
      "label": "Institution",
      "placeholder": "z.B.: TU Berlin"
    },
    "jobTitle": {
      "error": "Titel ist erforderlich",
      "label": "Professioneller Titel",
      "placeholder": "z.B.: Full Stack Entwickler"
    },
    "language": {
      "label": "Sprache",
      "level": {
        "A1": "A1 - Anfänger",
        "A2": "A2 - Grundkenntnisse",
        "B1": "B1 - Mittelstufe",
        "B2": "B2 - Gute Kenntnisse",
        "C1": "C1 - Fortgeschritten",
        "C2": "C2 - Fließend",
        "native": "Muttersprache"
      },
      "levelLabel": "Niveau",
      "placeholder": "Sprache auswählen..."
    },
    "linkedin": {
      "label": "LinkedIn",
      "placeholder": "https://linkedin.com/in/ihrprofil"
    },
    "location": {
      "label": "Standort",
      "placeholder": "z.B.: Berlin"
    },
    "month": { "placeholder": "Monat" },
    "year": { "placeholder": "Jahr" },
    "name": {
      "error": "Name ist erforderlich",
      "label": "Vollständiger Name",
      "placeholder": "z.B.: Max Mustermann"
    },
    "phone": {
      "error": "Ungültige Telefonnummer",
      "label": "Telefon",
      "note": { "placeholder": "Notiz (z.B.: Arbeit, Nachrichten...)" },
      "placeholder": "+49 000 00000000"
    },
    "profile": {
      "error": "Zeichenlimit von 400 erreicht",
      "label": "Berufliches Profil",
      "placeholder": "z.B.: Fachmann mit Erfahrung in..."
    },
    "skill": {
      "label": "Fähigkeiten",
      "placeholder": "z.B.: JavaScript, Photoshop..."
    },
    "startDate": { "label": "Startdatum" },
    "experience": { "current": "Aktuell" }
  },

